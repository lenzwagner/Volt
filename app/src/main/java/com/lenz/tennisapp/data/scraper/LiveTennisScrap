package com.lenz.tennisapp.data.scraper

import org.jsoup.Jsoup
import timber.log.Timber

data class PlayerRankingInfo(
    val playerName: String,
    val ranking: Int,
    val points: Int
)

data class PlayerPrizeMoney(
    val playerName: String,
    val prizeMoneyCurrentYear: Long  // in Euro
)

object LiveTennisScraper {

    suspend fun getATPRanking(playerName: String): PlayerRankingInfo? {
        return try {
            val url = "https://live-tennis.eu/en/atp-live-ranking"
            val doc = Jsoup.connect(url).get()

            // Find the player row by name
            val rows = doc.select("table tbody tr")
            rows.forEach { row ->
                val cells = row.select("td")
                if (cells.size >= 3) {
                    val name = cells[1].text().trim()
                    if (name.contains(playerName, ignoreCase = true)) {
                        val ranking = cells[0].text().trim().toIntOrNull() ?: return@forEach
                        val points = cells[2].text().trim()
                            .replace(".", "")  // Remove thousand separators
                            .toIntOrNull() ?: 0
                        return PlayerRankingInfo(name, ranking, points)
                    }
                }
            }
            null
        } catch (e: Exception) {
            Timber.e(e, "Error scraping ATP ranking")
            null
        }
    }

    suspend fun getWTARanking(playerName: String): PlayerRankingInfo? {
