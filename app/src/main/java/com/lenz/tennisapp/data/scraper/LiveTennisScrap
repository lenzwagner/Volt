    }

    suspend fun getATPPrizeMoney(playerName: String): PlayerPrizeMoney? {
        return try {
            val url = "https://live-tennis.eu/de/atp-preisgeld-des-laufenden-jahres"
            val doc = Jsoup.connect(url).get()

            val rows = doc.select("table tbody tr")
            rows.forEach { row ->
                val cells = row.select("td")
                if (cells.size >= 3) {
                    val name = cells[1].text().trim()
                    if (name.contains(playerName, ignoreCase = true)) {
                        val moneyStr = cells[2].text().trim()
                            .replace("€", "")
                            .replace(".", "")
                            .replace(",", "")
                            .trim()
                        val money = moneyStr.toLongOrNull() ?: 0L
                        return PlayerPrizeMoney(name, money)
                    }
                }
            }
            null
        } catch (e: Exception) {
            Timber.e(e, "Error scraping ATP prize money")
            null
        }
    }

