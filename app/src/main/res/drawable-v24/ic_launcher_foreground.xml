            <gradient
                android:type="radial"
                android:centerX="44"
                android:centerY="42"
                android:gradientRadius="46"
                android:startColor="#EAFF8A"
                android:endColor="#C2EE3B" />
        </aapt:attr>
    </path>

    <!-- Soft inner shadow on the lower-right for depth -->
    <path android:pathData="M54,24 a30,30 0 1,0 0.01,0 z">
        <aapt:attr name="android:fillColor">
