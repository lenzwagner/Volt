                android:type="radial"
                android:centerX="66"
                android:centerY="68"
                android:gradientRadius="40"
                android:startColor="#1A1D1B20"
                android:endColor="#00000000" />
        </aapt:attr>
    </path>

    <!-- Curved seams -->
    <path
        android:strokeColor="#1D1B20"
        android:strokeWidth="3.2"
        android:strokeLineCap="round"
        android:fillColor="#00000000"
        android:pathData="M31,32 C44,44 44,64 31,76" />
    <path
        android:strokeColor="#1D1B20"
