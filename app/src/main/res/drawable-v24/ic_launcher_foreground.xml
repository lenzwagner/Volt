    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Tennis ball, centered within the adaptive-icon safe zone -->
    <path android:pathData="M54,24 a30,30 0 1,0 0.01,0 z">
