<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.TennisApp" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:windowBackground">@android:color/white</item>
    </style>

    <!-- Theme für den Splash Screen -->
    <style name="Theme.App.Starting" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">#EDF7EA</item> <!-- BackgroundLight -->
        <item name="windowSplashScreenAnimatedIcon">@android:color/transparent</item>
        <item name="postSplashScreenTheme">@style/Theme.TennisApp</item>
    </style>
</resources>
